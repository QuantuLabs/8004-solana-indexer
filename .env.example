# ============================================================
# 8004 Solana Indexer
# ============================================================
#
# For network-ready profiles, use:
# - .env.devnet.example
# - .env.mainnet.example

# Database mode
# - supabase: GraphQL mode, or REST/both mode when PostgREST proxy auth is configured
# - local: native REST mode (SQLite/Prisma)
DB_MODE=supabase

# Supabase/PostgreSQL
SUPABASE_DSN=POSTGRES_DSN_REDACTED
SUPABASE_SSL_VERIFY=true
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_KEY=service_role_key

# Local Prisma (REST mode)
# To run REST with local SQLite, switch DB mode to local and set DATABASE_URL.

# Solana network + RPC
# Allowed: devnet | mainnet-beta | testnet | localnet
# Used to derive RPC/WS defaults when RPC_URL/WS_URL are unset
SOLANA_NETWORK=devnet
RPC_URL=https://api.devnet.solana.com
WS_URL=wss://api.devnet.solana.com
MAX_SUPPORTED_TRANSACTION_VERSION=0

# Program ID (defaults to devnet ID when unset)
PROGRAM_ID=8oo4J9tBB3Hna1jRQ3rWvJjojqM5DYTDJo5cejUuJy3C
ATOM_ENGINE_PROGRAM_ID=AToMufS4QD6hEXvcvBDg9m1AHeCLpmZQsyfYa5h9MwAF

# Optional ProofPass extra (PostgreSQL / Supabase only)
# Leave disabled unless the database has
# supabase/migrations/20260309192500_add_extra_proofpass_feedbacks.sql applied.
ENABLE_PROOFPASS=false
# PROOFPASS_PROGRAM_ID=72WFGnAp9EjPok7JbadCEC1j83TZe3ti8k6ax25dQVzG

# Optional startup cursor.
# If INDEXER_START_SIGNATURE + INDEXER_START_SLOT are both set, startup validates
# that the signature resolves to that exact slot and fails fast on mismatch.
# On an existing DB, the configured cursor is ignored unless it is ahead of
# saved state, in which case the poller fast-forwards persisted state.
# INDEXER_START_SIGNATURE=<exact_tx_signature>
# INDEXER_START_SLOT=<matching_slot_for_that_signature>
# Optional inclusive cutoff for deterministic parity/integrity runs
# INDEXER_STOP_SLOT=<slot_number>
# Recommended balanced polling profile.
# Runtime fallbacks in src/config.ts stay conservative; these values are the
# operator-facing baseline we recommend people start from.
POLLING_INTERVAL=10000
BATCH_SIZE=200
POLLER_MAX_SIGNATURES_PER_CYCLE=1000
POLLER_BATCH_RPC_ENABLED=true
POLLER_RPC_CHUNK_SIZE=100
POLLER_RPC_CHUNK_CONCURRENCY=4
HISTORICAL_SCAN_MAX_PAGES_PER_PASS=15
HISTORICAL_SCAN_SIGNATURE_PAGE_LIMIT=1000

# Faster bootstrap / parity profile (uncomment when you want raw catch-up speed
# and your RPC can handle it).
# POLLING_INTERVAL=5000
# BATCH_SIZE=200
# POLLER_MAX_SIGNATURES_PER_CYCLE=2000
# POLLER_BATCH_RPC_ENABLED=true
# POLLER_RPC_CHUNK_SIZE=200
# POLLER_RPC_CHUNK_CONCURRENCY=6
# HISTORICAL_SCAN_MAX_PAGES_PER_PASS=25
# HISTORICAL_SCAN_SIGNATURE_PAGE_LIMIT=1000
# For core-only parity runs, disable async metadata enrichment noise:
# INDEX_METADATA=off
# INDEX_COLLECTION_METADATA=false

# Mainnet profile lives in `.env.mainnet.example`.

# API mode
# graphql | rest | both
# - graphql requires DB_MODE=supabase
# - rest requires DB_MODE=local OR DB_MODE=supabase with PostgREST proxy auth
#   (SUPABASE_URL+SUPABASE_KEY or POSTGREST_URL+POSTGREST_TOKEN)
# - both is best-effort: one side is disabled if its DB backend is unavailable
API_MODE=graphql
ENABLE_GRAPHQL=true
API_PORT=3001
GRAPHQL_RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_REQUESTS=100
REPLAY_RATE_LIMIT_MAX_REQUESTS=1
REPLAY_RATE_LIMIT_WINDOW_MS=30000
# Reverse proxy trust for req.ip / rate-limit keys
# - false: direct exposure (recommended default)
# - 1 (or true): behind one trusted proxy
TRUST_PROXY=false
# Optional CORS allowlist (comma-separated). Leave unset for non-browser server-to-server usage.
# CORS_ORIGINS=https://your-app.example.com
# Cache TTL for globalStats/protocol aggregates (milliseconds)
GRAPHQL_STATS_CACHE_TTL_MS=60000
# Query complexity guards (GraphQL)
GRAPHQL_MAX_COMPLEXITY=3000
GRAPHQL_MAX_FIRST_CAP=400

# Verification
METRICS_ENDPOINT_ENABLED=false
VERIFY_INTERVAL_MS=60000
VERIFY_BATCH_SIZE=100
VERIFY_SAFETY_MARGIN_SLOTS=32
VERIFY_MAX_RETRIES=3
VERIFY_RECOVERY_CYCLES=10
VERIFY_RECOVERY_BATCH_SIZE=50

# Metadata extraction
INDEX_METADATA=normal
METADATA_MAX_BYTES=262144
METADATA_MAX_VALUE_BYTES=10000
# Retry cooldown for failed URI metadata recovery tasks (ms)
METADATA_RECOVERY_RETRY_MS=900000
# Maximum tracked assets in metadata recovery cooldown map.
METADATA_RECOVERY_MAX_COOLDOWN_ENTRIES=10000
# Cache TTL for DNS lookup failures (ENOTFOUND/EAI_*) to reduce retry storms.
# During this TTL, repeated lookups for the same hostname are blocked locally (ms).
URI_DIGEST_DNS_NEGATIVE_TTL_MS=600000
# Maximum cached failing hostnames retained for negative DNS cache.
URI_DIGEST_DNS_NEGATIVE_CACHE_MAX_ENTRIES=10000
# Collection CID ingestion (c1:<cid> -> JSON standard fields)
INDEX_COLLECTION_METADATA=true
# IPFS gateway base used by URI digest + collection digest pointer fetches
IPFS_GATEWAY_BASE=https://ipfs.io
# Optional local-only SSRF override for tests (only localhost,127.0.0.1 are allowed)
# URI_DIGEST_TRUSTED_HOSTS=127.0.0.1,localhost
# Unsafe: allows plain http:// metadata fetches
ALLOW_INSECURE_URI=false
# Validation ingestion (archived module; disabled by default outside tests)
INDEX_VALIDATIONS=false
